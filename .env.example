# Copy to .env.local and fill in. .env.local is gitignored.

# Vercel AI Gateway -------------------------------------------------------
# Required. Create at https://vercel.com/dashboard/ai-gateway (or via `vercel
# link` then `vercel env pull`). Routes streamText / generateText calls to
# upstream providers. We use BYOK so the keys below stay yours (zero markup).
AI_GATEWAY_API_KEY=

# Provider BYOK keys ------------------------------------------------------
# Configure these in the Vercel AI Gateway dashboard, not here. Listed only
# so you know which provider credentials Gateway routes through.
# - Google Gemini Flash       (Google AI Studio key)
# - DeepSeek V3               (https://platform.deepseek.com)
# - Moonshot Kimi K2          (https://platform.moonshot.cn)

# Upstash Redis (rate limiting) ------------------------------------------
# Optional but recommended. Vercel Storage -> Redis (Upstash) exposes these
# exact names. If unset, rate limiting fails open (chat still works).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Entitlement overrides --------------------------------------------------
# Optional. Override the defaults in lib/entitlements.ts without redeploying
# code. Tweak from the Vercel dashboard once you see real usage in the
# AI Gateway telemetry view.
#
# Anonymous tier (default values shown):
# TIER_ANON_CTX=16000
# TIER_ANON_MODELS=gemini-flash,deepseek-chat
# TIER_ANON_RPH=50
# TIER_ANON_THREADS=20
#
# Signed-in tier (placeholder until M4):
# TIER_FREE_CTX=32000
# TIER_FREE_MODELS=gemini-flash,deepseek-chat,kimi-k2
# TIER_FREE_RPH=100
# TIER_FREE_THREADS=50
#
# Premium tier (placeholder):
# TIER_PREMIUM_CTX=96000
# TIER_PREMIUM_MODELS=gemini-flash,deepseek-chat,kimi-k2
# TIER_PREMIUM_RPH=1000
# TIER_PREMIUM_THREADS=0     # 0 = unlimited

# Clerk (https://dashboard.clerk.com) -------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Custom auth pages (paths on this app)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/